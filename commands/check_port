#Get domain
if [ ! -z "$1" ]
then
    DOMAIN="$1"
else
    echo "ERROR: Must supply what domain to check"
    exit 3
fi

#Get port
if [ ! -z "$2" ]
then
    PORT="$2"
else
    echo "ERROR: Must supply what port to check"
    exit 3
fi

timeout 1 nc -z $DOMAIN $PORT </dev/null; result=$?

if [[ $result -gt 0 ]]; then
    echo "Failed connection to $DOMAIN:$PORT"
    exit 2
#else
#    echo "Connected to $DOMAIN:$PORT"
fi
