#Get domain
if [ ! -z "$1" ]
then
    DOMAIN="$1"
else
    echo "ERROR: Must supply what domain to check"
    exit 3
fi

#Get port
if [ ! -z "$2" ]
then
    PORT="$2"
else
    echo "ERROR: Must supply what port to check"
    exit 3
fi
result=$(timeout 0.1s netcat -v $DOMAIN $PORT)
if [[ $result == "" ]]; then
    echo "Failed";
    exit 2
fi

